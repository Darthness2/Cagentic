{
  "manifest_version": 3,
  "name": "Cagentic Bridge",
  "version": "0.1.0",
  "description": "Lets your local Cagentic assistant see and act in this browser.",
  "permissions": ["tabs", "scripting", "alarms", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cagentic Bridge"
  }
}
